# Supabase — copy these from your Supabase project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# A shared ID that scopes all data to your household.
# Pick any string (e.g. your names, a UUID). Both you and your girlfriend
# must use the exact same value so you see each other's data.
VITE_HOUSEHOLD_ID=jake-and-girlfriend
